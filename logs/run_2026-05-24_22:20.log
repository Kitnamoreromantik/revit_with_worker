{
    t.Start();
    XYZ p1 = new XYZ(0, 0, 0);
    XYZ p2 = new XYZ(10, 0, 0);
    Wall wall = doc.Create.NewWall(p1, p2, level, wallType);
    t.Commit();
}
return "Wall created.";

